#include <stdio.h>

int main() {
    int numbers[] = {2, 7, 11, 15};
    int target = 9;
    int n = 4;

    int left = 0;
    int right = n - 1;

    while(left < right) {
        int sum = numbers[left] + numbers[right];

        if(sum == target) {
            printf("[%d, %d]", left + 1, right + 1);
            return 0;
        }
        else if(sum < target) {
            left++;
        }
        else {
            right--;
        }
    }

    return 0;
}

