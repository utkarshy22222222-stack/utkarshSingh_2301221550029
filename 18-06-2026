#include <stdio.h>

int main() {
    int nums[] = {3, 2, 3};
    int n = 3;

    int candidate = 0;
    int count = 0;
    int i;

    for(i = 0; i < n; i++) {
        if(count == 0) {
            candidate = nums[i];
        }

        if(nums[i] == candidate) {
            count++;
        } else {
            count--;
        }
    }

    printf("Majority Element = %d", candidate);

    return 0;
}

