#include <stdio.h>

int main() {
    int arr[] = {3, 4, 2, 8, 12, 9};
    int size = 6;
    int i;

    int largest = arr[0];
    int secondLargest = arr[0];

    for(i = 0; i < size; i++) {
        if(arr[i] > largest) {
            largest = arr[i];
        }
    }

    for(i = 0; i < size; i++) {
        if(arr[i] > secondLargest && arr[i] != largest) {
            secondLargest = arr[i];
        }
    }

    printf("Largest element = %d\n", largest);
    printf("Second largest element = %d\n", secondLargest);

    return 0;
}

