#include <stdio.h>

int main() {
    int arr[] = {3, 4, 2, 8, 12, 9};
    int size = 6;
    int i;
    int max;

    max = arr[0];

    for(i = 1; i < size; i++) {
        if(arr[i] > max) {
            max = arr[i];
        }
    }

    printf("Largest element in array is: %d\n", max);

    return 0;
}

