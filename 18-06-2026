#include <stdio.h>

int main() {
    int nums[] = {1, 1, 1};
    int k = 2;
    int n = 3;

    int map[10000] = {0};
    map[0] = 1;

    int sum = 0;
    int count = 0;
    int i;

    for(i = 0; i < n; i++) {
        sum += nums[i];

        if(sum - k >= 0) {
            count += map[sum - k];
        }

        map[sum]++;
    }

    printf("Count = %d", count);

    return 0;
}
