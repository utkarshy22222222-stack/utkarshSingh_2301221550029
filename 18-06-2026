#include <stdio.h>

int main() {
    int nums[] = {2, 7, 11, 15};
    int target = 9;
    int n = 4;

    int map[10000];
    int i;

    for(i = 0; i < 10000; i++) {
        map[i] = -1;
    }

    for(i = 0; i < n; i++) {
        int need = target - nums[i];

        if(need >= 0 && need < 10000 && map[need] != -1) {
            printf("[%d, %d]", map[need], i);
            return 0;
        }

        if(nums[i] >= 0 && nums[i] < 10000) {
            map[nums[i]] = i;
        }
    }

    return 0;
}

