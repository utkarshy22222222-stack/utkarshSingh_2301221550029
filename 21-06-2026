#include <stdio.h>

int undo[10], redo[10];
int utop = -1, rtop = -1;

int main() {
    undo[++utop] = 10;
    undo[++utop] = 20;
    undo[++utop] = 30;

    printf("Undo Stack: ");
    for(int i = utop; i >= 0; i--)
        printf("%d ", undo[i]);

    redo[++rtop] = undo[utop--];

    printf("\nAfter Undo: ");
    for(int i = utop; i >= 0; i--)
        printf("%d ", undo[i]);

    undo[++utop] = redo[rtop--];

    printf("\nAfter Redo: ");
    for(int i = utop; i >= 0; i--)
        printf("%d ", undo[i]);

    return 0;
}
